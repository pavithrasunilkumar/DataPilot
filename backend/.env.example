# Database
DATABASE_URL=postgresql://datapilot:datapilot@localhost:5432/datapilot

# Auth
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# LLM provider — used later in Phase 5 (AI Analyst).
# Not required yet for Phase 1 (upload + profiling).
LLM_PROVIDER=groq
GROQ_API_KEY=your-free-groq-api-key-here

# Comma-separated list of extra allowed CORS origins (local dev origins are
# always included automatically). Set this to your deployed Vercel URL.
ALLOWED_ORIGINS=

# File storage
UPLOAD_DIR=./uploaded_files
MAX_UPLOAD_MB=25
